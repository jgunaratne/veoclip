PORT=8080

# ---------------------------------------------------------------------------
# Veo / Video generation — pick ONE auth strategy
# ---------------------------------------------------------------------------

# Option A: Vertex AI (requires a GCP project + Application Default Credentials)
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Option B: Gemini API key (no GCP project needed)
# GEMINI_API_KEY=your-gemini-api-key

# Model to use (applies to both options above)
VEO_MODEL=veo-2.0-generate-001

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output
