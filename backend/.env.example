PORT=8080

# ---------------------------------------------------------------------------
# Google AI — pick ONE auth strategy (GEMINI_API_KEY wins if both are set)
# ---------------------------------------------------------------------------

# Option A (preferred): Gemini API key — gives access to the latest models
# (veo-3.1, gemini-3.5). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Option B: Vertex AI (requires a GCP project + Application Default Credentials)
# GCP_PROJECT_ID=your-project-id
# GCP_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ---------------------------------------------------------------------------
# Models (optional — sensible defaults per auth mode)
# ---------------------------------------------------------------------------

# Video model. Defaults: veo-2.0-generate-001 (Vertex), veo-3.1-fast-generate-preview (Gemini)
# VEO_MODEL=veo-3.1-fast-generate-preview

# Story/script model (narration + scene prompts). Default: gemini-3.5-flash
# GEMINI_TEXT_MODEL=gemini-3.5-flash

# TTS model, Gemini API mode only. Default: gemini-3.1-flash-tts-preview
# TTS_MODEL=gemini-3.1-flash-tts-preview

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output
